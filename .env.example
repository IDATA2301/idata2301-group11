# Frontend env template. Copy to .env (campus defaults) and optionally
# override per machine in .env.local (gitignored via *.local).

# Base prefix for API calls. Leave as-is.
VITE_API_BASE_URL=/api

# Vite dev-server proxy targets.
# Campus: both point at the NTNU server.
# Home (local backend): VITE_API_TARGET=http://localhost:8080
# Home (no image proxy):  VITE_IMAGES_TARGET=    (empty -> Vite serves public/images/*)
VITE_API_TARGET=http://10.212.27.62
VITE_IMAGES_TARGET=http://10.212.27.62
